# ===== SERVER CONFIGURATION =====

# Port server chạy (local: 5000, Render: 10000)
PORT=5000

# MongoDB Atlas connection string
# Thay username, password và cluster bằng thông tin của bạn
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/noteapp?retryWrites=true&w=majority

# JWT Secret key (sử dụng key ngẫu nhiên)
JWT_SECRET=supersecretkey

# Environment (development | production)
NODE_ENV=development

# ===== CORS ORIGINS =====
# QUAN TRỌNG: Thêm URL frontend vào đây (phân cách bằng dấu phẩy)
# Production: thêm URL Vercel của bạn
# Ví dụ: CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
